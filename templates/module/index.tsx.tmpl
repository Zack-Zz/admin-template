import { PlusOutlined } from '@ant-design/icons';
import { type ActionType, PageContainer } from '@ant-design/pro-components';
import { useIntl } from '@umijs/max';
import { message } from 'antd';
import { useRef, useState } from 'react';
import { BizPermissionButton } from '@/components';
import __ModuleName__DetailDrawer from './components/__ModuleName__DetailDrawer';
import __ModuleName__FormModal from './components/__ModuleName__FormModal';
import __ModuleName__Table from './components/__ModuleName__Table';
import {
  create__ModuleName__,
  delete__ModuleName__,
  update__ModuleName__,
} from './service';
import type { __ModuleName__FormValues, __ModuleName__Item } from './types';

const __ModuleName__Page = () => {
  const intl = useIntl();
  const actionRef = useRef<ActionType | null>(null);
  const [messageApi, contextHolder] = message.useMessage();
  const [saving, setSaving] = useState(false);
  const [formOpen, setFormOpen] = useState(false);
  const [currentRecord, setCurrentRecord] = useState<__ModuleName__Item>();
  const [detailOpen, setDetailOpen] = useState(false);

  const closeForm = () => {
    setFormOpen(false);
    setCurrentRecord(undefined);
  };

  const handleSubmit = async (values: __ModuleName__FormValues) => {
    setSaving(true);
    try {
      if (currentRecord) {
        await update__ModuleName__(currentRecord.id, values);
        messageApi.success(
          intl.formatMessage({
            id: 'pages.__groupName__.__modulePath__.message.updated',
            defaultMessage: '__moduleTitleEn__ updated',
          }),
        );
      } else {
        await create__ModuleName__(values);
        messageApi.success(
          intl.formatMessage({
            id: 'pages.__groupName__.__modulePath__.message.created',
            defaultMessage: '__moduleTitleEn__ created',
          }),
        );
      }
      closeForm();
      await actionRef.current?.reload();
    } finally {
      setSaving(false);
    }
  };

  const handleDelete = async (record: __ModuleName__Item) => {
    await delete__ModuleName__(record.id);
    messageApi.success(
      intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.message.deleted',
        defaultMessage: '__moduleTitleEn__ deleted',
      }),
    );
    await actionRef.current?.reload();
  };

  return (
    <PageContainer>
      {contextHolder}
      <__ModuleName__Table
        actionRef={actionRef}
        toolBarRender={() => [
          <BizPermissionButton
            key="create"
            hiddenWhenDenied
            permissionCode="__groupName__:__modulePath__:create"
            type="primary"
            icon={<PlusOutlined />}
            onClick={() => {
              setCurrentRecord(undefined);
              setFormOpen(true);
            }}
          >
            {intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.action.create',
              defaultMessage: 'New',
            })}
          </BizPermissionButton>,
        ]}
        onView={(record) => {
          setCurrentRecord(record);
          setDetailOpen(true);
        }}
        onEdit={(record) => {
          setCurrentRecord(record);
          setFormOpen(true);
        }}
        onDelete={handleDelete}
      />
      <__ModuleName__FormModal
        open={formOpen}
        mode={currentRecord ? 'edit' : 'create'}
        values={currentRecord}
        confirmLoading={saving}
        onCancel={closeForm}
        onSubmit={handleSubmit}
      />
      <__ModuleName__DetailDrawer
        open={detailOpen}
        record={currentRecord}
        onClose={() => {
          setDetailOpen(false);
          setCurrentRecord(undefined);
        }}
      />
    </PageContainer>
  );
};

export default __ModuleName__Page;
