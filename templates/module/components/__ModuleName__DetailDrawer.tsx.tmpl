import {
  ProDescriptions,
  type ProDescriptionsItemProps,
} from '@ant-design/pro-components';
import { useIntl } from '@umijs/max';
import { Drawer } from 'antd';
import { BizStatusTag } from '@/components';
import { __ModuleName___STATUS_TAG_OPTIONS } from '../constants';
import type { __ModuleName__Item } from '../types';

interface __ModuleName__DetailDrawerProps {
  open: boolean;
  record?: __ModuleName__Item;
  onClose: () => void;
}

const __ModuleName__DetailDrawer = ({
  open,
  record,
  onClose,
}: __ModuleName__DetailDrawerProps) => {
  const intl = useIntl();
  const statusOptions = __ModuleName___STATUS_TAG_OPTIONS.map((item) => ({
    ...item,
    label: intl.formatMessage({
      id:
        item.value === 1
          ? 'pages.__groupName__.__modulePath__.status.enabled'
          : 'pages.__groupName__.__modulePath__.status.disabled',
      defaultMessage: String(item.label),
    }),
  }));
  const columns: ProDescriptionsItemProps<__ModuleName__Item>[] = [
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.name',
        defaultMessage: 'Name',
      }),
      dataIndex: 'name',
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.code',
        defaultMessage: 'Code',
      }),
      dataIndex: 'code',
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.status',
        defaultMessage: 'Status',
      }),
      dataIndex: 'status',
      render: (_, entity) => (
        <BizStatusTag value={entity.status} options={statusOptions} />
      ),
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.owner',
        defaultMessage: 'Owner',
      }),
      dataIndex: 'owner',
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.description',
        defaultMessage: 'Description',
      }),
      dataIndex: 'description',
      render: (_, entity) => entity.description || '-',
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.createdAt',
        defaultMessage: 'Created At',
      }),
      dataIndex: 'createdAt',
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.updatedAt',
        defaultMessage: 'Updated At',
      }),
      dataIndex: 'updatedAt',
    },
  ];

  return (
    <Drawer
      title={intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.detail.title',
        defaultMessage: '__moduleTitleEn__ Details',
      })}
      open={open}
      onClose={onClose}
      size={600}
      destroyOnHidden
    >
      {record && (
        <ProDescriptions<__ModuleName__Item>
          column={1}
          dataSource={record}
          columns={columns}
        />
      )}
    </Drawer>
  );
};

export default __ModuleName__DetailDrawer;
