import {
  ModalForm,
  ProFormSelect,
  ProFormText,
  ProFormTextArea,
} from '@ant-design/pro-components';
import { __ModuleName___STATUS_OPTIONS } from '../constants';
import type { __ModuleName__FormValues, __ModuleName__Item } from '../types';

interface __ModuleName__FormModalProps {
  open: boolean;
  mode: 'create' | 'edit';
  values?: __ModuleName__Item;
  confirmLoading?: boolean;
  onCancel: () => void;
  onSubmit: (values: __ModuleName__FormValues) => void | Promise<void>;
}

const __ModuleName__FormModal = ({
  open,
  mode,
  values,
  confirmLoading,
  onCancel,
  onSubmit,
}: __ModuleName__FormModalProps) => {
  return (
    <ModalForm<__ModuleName__FormValues>
      key={values?.id ?? 'create'}
      title={mode === 'create' ? '新增__moduleTitle__' : '编辑__moduleTitle__'}
      open={open}
      initialValues={values ?? { status: 1 }}
      modalProps={{
        destroyOnHidden: true,
        okButtonProps: { loading: confirmLoading },
        onCancel,
      }}
      onOpenChange={(nextOpen) => {
        if (!nextOpen) {
          onCancel();
        }
      }}
      onFinish={async (formValues) => {
        await onSubmit(formValues);

        return true;
      }}
    >
      <ProFormText
        name="name"
        label="名称"
        rules={[{ required: true, message: '请输入名称' }]}
        fieldProps={{ maxLength: 40 }}
        placeholder="请输入名称"
      />
      <ProFormText
        name="code"
        label="编码"
        rules={[{ required: true, message: '请输入编码' }]}
        fieldProps={{ maxLength: 40 }}
        placeholder="请输入编码"
      />
      <ProFormSelect
        name="status"
        label="状态"
        rules={[{ required: true, message: '请选择状态' }]}
        options={__ModuleName___STATUS_OPTIONS}
        placeholder="请选择状态"
      />
      <ProFormText
        name="owner"
        label="负责人"
        rules={[{ required: true, message: '请输入负责人' }]}
        fieldProps={{ maxLength: 40 }}
        placeholder="请输入负责人"
      />
      <ProFormTextArea
        name="description"
        label="描述"
        fieldProps={{ maxLength: 200, showCount: true }}
        placeholder="请输入描述"
      />
    </ModalForm>
  );
};

export default __ModuleName__FormModal;
