import {
  ModalForm,
  ProFormSelect,
  ProFormText,
  ProFormTextArea,
} from '@ant-design/pro-components';
import { useIntl } from '@umijs/max';
import { __ModuleName___STATUS_TAG_OPTIONS } from '../constants';
import type { __ModuleName__FormValues, __ModuleName__Item } from '../types';

interface __ModuleName__FormModalProps {
  open: boolean;
  mode: 'create' | 'edit';
  values?: __ModuleName__Item;
  confirmLoading?: boolean;
  onCancel: () => void;
  onSubmit: (values: __ModuleName__FormValues) => void | Promise<void>;
}

const __ModuleName__FormModal = ({
  open,
  mode,
  values,
  confirmLoading,
  onCancel,
  onSubmit,
}: __ModuleName__FormModalProps) => {
  const intl = useIntl();
  const statusOptions = __ModuleName___STATUS_TAG_OPTIONS.map((item) => ({
    ...item,
    label: intl.formatMessage({
      id:
        item.value === 1
          ? 'pages.__groupName__.__modulePath__.status.enabled'
          : 'pages.__groupName__.__modulePath__.status.disabled',
      defaultMessage: String(item.label),
    }),
  }));

  return (
    <ModalForm<__ModuleName__FormValues>
      key={values?.id ?? 'create'}
      title={intl.formatMessage({
        id:
          mode === 'create'
            ? 'pages.__groupName__.__modulePath__.form.createTitle'
            : 'pages.__groupName__.__modulePath__.form.editTitle',
        defaultMessage:
          mode === 'create'
            ? 'Create __moduleTitleEn__'
            : 'Edit __moduleTitleEn__',
      })}
      open={open}
      initialValues={values ?? { status: 1 }}
      modalProps={{
        destroyOnHidden: true,
        okButtonProps: { loading: confirmLoading },
        onCancel,
      }}
      onOpenChange={(nextOpen) => {
        if (!nextOpen) {
          onCancel();
        }
      }}
      onFinish={async (formValues) => {
        await onSubmit(formValues);

        return true;
      }}
    >
      <ProFormText
        name="name"
        label={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.field.name',
          defaultMessage: 'Name',
        })}
        rules={[
          {
            required: true,
            message: intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.validation.nameRequired',
              defaultMessage: 'Please enter name',
            }),
          },
        ]}
        fieldProps={{ maxLength: 40 }}
        placeholder={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.placeholder.name',
          defaultMessage: 'Please enter name',
        })}
      />
      <ProFormText
        name="code"
        label={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.field.code',
          defaultMessage: 'Code',
        })}
        rules={[
          {
            required: true,
            message: intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.validation.codeRequired',
              defaultMessage: 'Please enter code',
            }),
          },
        ]}
        fieldProps={{ maxLength: 40 }}
        placeholder={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.placeholder.code',
          defaultMessage: 'Please enter code',
        })}
      />
      <ProFormSelect
        name="status"
        label={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.field.status',
          defaultMessage: 'Status',
        })}
        rules={[
          {
            required: true,
            message: intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.validation.statusRequired',
              defaultMessage: 'Please select status',
            }),
          },
        ]}
        options={statusOptions}
        placeholder={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.placeholder.status',
          defaultMessage: 'Please select status',
        })}
      />
      <ProFormText
        name="owner"
        label={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.field.owner',
          defaultMessage: 'Owner',
        })}
        rules={[
          {
            required: true,
            message: intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.validation.ownerRequired',
              defaultMessage: 'Please enter owner',
            }),
          },
        ]}
        fieldProps={{ maxLength: 40 }}
        placeholder={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.placeholder.owner',
          defaultMessage: 'Please enter owner',
        })}
      />
      <ProFormTextArea
        name="description"
        label={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.field.description',
          defaultMessage: 'Description',
        })}
        fieldProps={{ maxLength: 200, showCount: true }}
        placeholder={intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.placeholder.description',
          defaultMessage: 'Please enter description',
        })}
      />
    </ModalForm>
  );
};

export default __ModuleName__FormModal;
