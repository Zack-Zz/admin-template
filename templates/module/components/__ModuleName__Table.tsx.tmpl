import type { ActionType, ProColumns } from '@ant-design/pro-components';
import { ProTable } from '@ant-design/pro-components';
import { useIntl } from '@umijs/max';
import { Button, Popconfirm, Space } from 'antd';
import type { ReactNode, RefObject } from 'react';
import { BizPermissionButton, BizStatusTag, useBizPermission } from '@/components';
import {
  DEFAULT_PAGE_SIZE,
  __ModuleName___STATUS_TAG_OPTIONS,
} from '../constants';
import { query__ModuleName__List } from '../service';
import type {
  __ModuleName__Item,
  __ModuleName__Query,
  __ModuleName__Status,
} from '../types';

interface __ModuleName__TableParams extends Omit<__ModuleName__Query, 'status'> {
  current?: number;
  status?: __ModuleName__Status | string;
}

interface __ModuleName__TableProps {
  actionRef?: RefObject<ActionType | null>;
  toolBarRender?: () => ReactNode[];
  onView: (record: __ModuleName__Item) => void;
  onEdit: (record: __ModuleName__Item) => void;
  onDelete: (record: __ModuleName__Item) => void | Promise<void>;
}

const __ModuleName__Table = ({
  actionRef,
  toolBarRender,
  onView,
  onEdit,
  onDelete,
}: __ModuleName__TableProps) => {
  const intl = useIntl();
  const canDelete = useBizPermission('__groupName__:__modulePath__:delete');
  const statusOptions = __ModuleName___STATUS_TAG_OPTIONS.map((item) => ({
    ...item,
    label: intl.formatMessage({
      id:
        item.value === 1
          ? 'pages.__groupName__.__modulePath__.status.enabled'
          : 'pages.__groupName__.__modulePath__.status.disabled',
      defaultMessage: String(item.label),
    }),
  }));
  const statusValueEnum = Object.fromEntries(
    statusOptions.map((item) => [String(item.value), { text: item.label }]),
  );
  const normalizeStatus = (
    status: __ModuleName__TableParams['status'],
  ): __ModuleName__Status | undefined => {
    if (status === undefined || status === '') {
      return undefined;
    }

    return Number(status) as __ModuleName__Status;
  };

  const columns: ProColumns<__ModuleName__Item>[] = [
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.keyword',
        defaultMessage: 'Keyword',
      }),
      dataIndex: 'keyword',
      hideInTable: true,
      fieldProps: {
        allowClear: true,
        placeholder: intl.formatMessage({
          id: 'pages.__groupName__.__modulePath__.placeholder.keyword',
          defaultMessage: 'Name / Code / Owner',
        }),
      },
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.name',
        defaultMessage: 'Name',
      }),
      dataIndex: 'name',
      key: 'name',
      search: false,
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.code',
        defaultMessage: 'Code',
      }),
      dataIndex: 'code',
      key: 'code',
      search: false,
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.status',
        defaultMessage: 'Status',
      }),
      dataIndex: 'status',
      key: 'status',
      valueType: 'select',
      valueEnum: statusValueEnum,
      render: (_, entity) => (
        <BizStatusTag value={entity.status} options={statusOptions} />
      ),
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.owner',
        defaultMessage: 'Owner',
      }),
      dataIndex: 'owner',
      key: 'owner',
      search: false,
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.updatedAt',
        defaultMessage: 'Updated At',
      }),
      dataIndex: 'updatedAt',
      key: 'updatedAt',
      search: false,
    },
    {
      title: intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.field.action',
        defaultMessage: 'Action',
      }),
      key: 'action',
      width: 180,
      valueType: 'option',
      render: (_, record) => (
        <Space>
          <BizPermissionButton
            hiddenWhenDenied
            permissionCode="__groupName__:__modulePath__:view"
            type="link"
            onClick={() => onView(record)}
          >
            {intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.action.view',
              defaultMessage: 'View',
            })}
          </BizPermissionButton>
          <BizPermissionButton
            hiddenWhenDenied
            permissionCode="__groupName__:__modulePath__:update"
            type="link"
            onClick={() => onEdit(record)}
          >
            {intl.formatMessage({
              id: 'pages.__groupName__.__modulePath__.action.edit',
              defaultMessage: 'Edit',
            })}
          </BizPermissionButton>
          {canDelete && (
            <Popconfirm
              title={intl.formatMessage({
                id: 'pages.__groupName__.__modulePath__.delete.title',
                defaultMessage: 'Delete this record?',
              })}
              description={intl.formatMessage({
                id: 'pages.__groupName__.__modulePath__.delete.description',
                defaultMessage:
                  'This only affects the local scaffold example data.',
              })}
              okText={intl.formatMessage({
                id: 'pages.__groupName__.__modulePath__.action.delete',
                defaultMessage: 'Delete',
              })}
              okButtonProps={{ danger: true }}
              onConfirm={() => onDelete(record)}
            >
              <Button danger type="link">
                {intl.formatMessage({
                  id: 'pages.__groupName__.__modulePath__.action.delete',
                  defaultMessage: 'Delete',
                })}
              </Button>
            </Popconfirm>
          )}
        </Space>
      ),
    },
  ];

  return (
    <ProTable<__ModuleName__Item, __ModuleName__TableParams>
      actionRef={actionRef}
      headerTitle={intl.formatMessage({
        id: 'pages.__groupName__.__modulePath__.title',
        defaultMessage: '__moduleTitleEn__',
      })}
      rowKey="id"
      search={{ labelWidth: 100 }}
      columns={columns}
      pagination={{
        defaultPageSize: DEFAULT_PAGE_SIZE,
        showSizeChanger: true,
      }}
      toolBarRender={toolBarRender}
      request={async (params) => {
        const result = await query__ModuleName__List({
          pageNo: params.current ?? 1,
          pageSize: params.pageSize ?? DEFAULT_PAGE_SIZE,
          keyword: params.keyword,
          status: normalizeStatus(params.status),
        });

        return {
          data: result.records,
          total: result.total,
          success: true,
        };
      }}
    />
  );
};

export default __ModuleName__Table;
